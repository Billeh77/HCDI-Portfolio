# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# Large video binaries (GitHub rejects files > 100MB; pushes also time out on huge packs).
# Keep your .mp4 on disk for local dev; on Vercel set NEXT_PUBLIC_PORTFOLIO_VIDEO_URL to a direct HTTPS link.
/public/portfolio/video/*.mp4
/public/portfolio/video/*.mov
/public/portfolio/video/*.webm

# typescript
*.tsbuildinfo
next-env.d.ts
